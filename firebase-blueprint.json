{
  "entities": {
    "ThimbleBoard": {
      "title": "ThimbleBoard",
      "description": "A sourcing board for grouping external links.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who owns the board." },
        "title": { "type": "string", "description": "Title of the board." },
        "description": { "type": "string", "description": "Optional description of the board." },
        "createdAt": { "type": "number", "description": "Timestamp of creation." },
        "updatedAt": { "type": "number", "description": "Timestamp of last update." }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "ThimbleItem": {
      "title": "ThimbleItem",
      "description": "An item within a sourcing board.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who owns the item." },
        "boardId": { "type": "string", "description": "ID of the board this item belongs to." },
        "url": { "type": "string", "description": "URL of the item." },
        "title": { "type": "string", "description": "Optional title of the item." },
        "price": { "type": "string", "description": "Optional price of the item." },
        "notes": { "type": "string", "description": "Optional notes for the item." },
        "createdAt": { "type": "number", "description": "Timestamp of creation." }
      },
      "required": ["userId", "boardId", "url", "createdAt"]
    },
    "LineageEntry": {
      "title": "LineageEntry",
      "description": "Records the provenance and archetypal synthesis of a creative artifact.",
      "type": "object",
      "properties": {
        "artifact_id": { "type": "string", "description": "ID of the generated artifact (e.g., Zine ID)." },
        "userId": { "type": "string", "description": "ID of the user who created the lineage entry." },
        "thought_signature": { "type": "string", "description": "Cryptographic fingerprint of the reasoning process." },
        "fragment_ids": { "type": "array", "description": "IDs of raw debris/fragments used.", "items": { "type": "string" } },
        "archetype_weights": { "type": "object", "description": "The dominant archetype weights." },
        "synthesis_notes": { "type": "string", "description": "Philosophical bridge/notes on the synthesis." },
        "timestamp": { "type": "number", "description": "Timestamp of creation." }
      },
      "required": ["artifact_id", "userId", "thought_signature", "fragment_ids", "archetype_weights", "synthesis_notes", "timestamp"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "handle": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["uid", "handle"]
    },
    "Stack": {
      "title": "Stack",
      "description": "A collection of pocket items.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "userId", "name"]
    },
    "PublicTransmission": {
      "title": "PublicTransmission",
      "description": "A public message or artifact.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "content", "timestamp"]
    },
    "PocketItem": {
      "title": "PocketItem",
      "description": "An item saved to the user's pocket.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "timestamp": { "type": "number" },
        "stackIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "type", "title", "timestamp"]
    },
    "Zine": {
      "title": "Zine",
      "description": "A generated zine.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "isPublic": { "type": "boolean" }
      },
      "required": ["id", "userId", "title"]
    },
    "DossierFolder": {
      "title": "DossierFolder",
      "description": "A folder in the dossier.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "collaborators": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "name"]
    },
    "DossierArtifact": {
      "title": "DossierArtifact",
      "description": "An artifact in the dossier.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "folderId": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "userId", "folderId"]
    },
    "Proposal": {
      "title": "Proposal",
      "description": "A generated proposal.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" }
      },
      "required": ["id", "userId", "title"]
    },
    "Context": {
      "title": "Context",
      "description": "Context data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "userId"]
    },
    "ZineComment": {
      "title": "ZineComment",
      "description": "A comment on a zine.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "zineId": { "type": "string" },
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "zineId", "userId", "content", "timestamp"]
    },
    "TasteEvent": {
      "title": "TasteEvent",
      "description": "A taste event log.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "artifactId": { "type": "string" },
        "aestheticVector": { "type": "object" },
        "similarityScore": { "type": "number" },
        "trajectoryLabel": { "type": "string" },
        "interpretation": { "type": "string" },
        "confidence": { "type": "number" },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "artifactId", "aestheticVector", "similarityScore", "trajectoryLabel", "interpretation", "confidence", "timestamp"]
    },
    "Memory": {
      "title": "Memory",
      "description": "A memory item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["id", "content"]
    },
    "RetentionEvent": {
      "title": "RetentionEvent",
      "description": "A retention event.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "timestamp"]
    },
    "Connection": {
      "title": "Connection",
      "description": "A user connection.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "followerId": { "type": "string" },
        "followingId": { "type": "string" }
      },
      "required": ["id", "followerId", "followingId"]
    },
    "FriendRequest": {
      "title": "FriendRequest",
      "description": "A friend request.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "senderId", "receiverId", "status"]
    },
    "Friendship": {
      "title": "Friendship",
      "description": "A friendship.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user1": { "type": "string" },
        "user2": { "type": "string" }
      },
      "required": ["id", "user1", "user2"]
    },
    "Theme": {
      "title": "Theme",
      "description": "A clustered theme.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Constellation": {
      "title": "Constellation",
      "description": "A manual grouping of artifacts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "artifactIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "artifactIds", "createdAt", "updatedAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A user notification.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "link": { "type": "string" },
        "timestamp": { "type": "number" },
        "read": { "type": "boolean" }
      },
      "required": ["id", "userId", "message", "timestamp", "read"]
    },
    "TasteGraphNode": {
      "title": "TasteGraphNode",
      "description": "A node in the semantic taste graph.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "type": { "type": "string", "enum": ["concept", "motif", "era"] },
        "weight": { "type": "number" }
      },
      "required": ["id", "label", "type", "weight"]
    },
    "TasteGraphEdge": {
      "title": "TasteGraphEdge",
      "description": "An edge in the semantic taste graph.",
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" },
        "strength": { "type": "number" },
        "type": { "type": "string", "enum": ["relates_to", "evolves_from", "contrasts_with"] }
      },
      "required": ["source", "target", "strength", "type"]
    }
  },
  "firestore": {
    "thimbleBoards/{boardId}": {
      "schema": { "$ref": "#/entities/ThimbleBoard" },
      "description": "Sourcing boards for grouping external links."
    },
    "thimbleItems/{itemId}": {
      "schema": { "$ref": "#/entities/ThimbleItem" },
      "description": "Items within a sourcing board."
    },
    "lineage_entries/{lineageId}": {
      "schema": { "$ref": "#/entities/LineageEntry" },
      "description": "Collection of provenance lineage records."
    },
    "profiles/{profileId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles."
    },
    "stacks/{stackId}": {
      "schema": { "$ref": "#/entities/Stack" },
      "description": "User stacks."
    },
    "public_transmissions/{transmissionId}": {
      "schema": { "$ref": "#/entities/PublicTransmission" },
      "description": "Public transmissions."
    },
    "pocket/{pocketId}": {
      "schema": { "$ref": "#/entities/PocketItem" },
      "description": "Pocket items."
    },
    "zines/{zineId}": {
      "schema": { "$ref": "#/entities/Zine" },
      "description": "Generated zines."
    },
    "dossier_folders/{folderId}": {
      "schema": { "$ref": "#/entities/DossierFolder" },
      "description": "Dossier folders."
    },
    "dossier_artifacts/{artifactId}": {
      "schema": { "$ref": "#/entities/DossierArtifact" },
      "description": "Dossier artifacts."
    },
    "proposals/{proposalId}": {
      "schema": { "$ref": "#/entities/Proposal" },
      "description": "Generated proposals."
    },
    "context/{contextId}": {
      "schema": { "$ref": "#/entities/Context" },
      "description": "Context data."
    },
    "zine_comments/{commentId}": {
      "schema": { "$ref": "#/entities/ZineComment" },
      "description": "Zine comments."
    },
    "taste_events/{eventId}": {
      "schema": { "$ref": "#/entities/TasteEvent" },
      "description": "Taste events."
    },
    "users/{userId}/memory/{memoryId}": {
      "schema": { "$ref": "#/entities/Memory" },
      "description": "User memories."
    },
    "retention_events/{userId}/sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/RetentionEvent" },
      "description": "Retention events."
    },
    "connections/{connectionId}": {
      "schema": { "$ref": "#/entities/Connection" },
      "description": "User connections."
    },
    "friend_requests/{requestId}": {
      "schema": { "$ref": "#/entities/FriendRequest" },
      "description": "Friend requests."
    },
    "friendships/{friendshipId}": {
      "schema": { "$ref": "#/entities/Friendship" },
      "description": "Friendships."
    },
    "users/{userId}/themes/{themeId}": {
      "schema": { "$ref": "#/entities/Theme" },
      "description": "User themes."
    },
    "users/{userId}/constellations/{constellationId}": {
      "schema": { "$ref": "#/entities/Constellation" },
      "description": "User constellations."
    },
    "notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "User notifications."
    },
    "users/{userId}/tasteGraphNodes/{nodeId}": {
      "schema": { "$ref": "#/entities/TasteGraphNode" },
      "description": "User taste graph nodes."
    },
    "users/{userId}/tasteGraphEdges/{edgeId}": {
      "schema": { "$ref": "#/entities/TasteGraphEdge" },
      "description": "User taste graph edges."
    }
  }
}
