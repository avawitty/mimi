
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // PUBLIC PROFILES (Read: Everyone, Write: Owner)
    match /profiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // PRIVATE PREFERENCES (Read/Write: Owner only)
    match /userPreferences/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // LEGACY / FALLBACK (Read/Write: Owner only)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /memory/{memoryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /themes/{themeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /threads/{threadId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // ZINES (Read: Public, Write: Authenticated or Collaborator)
    match /zines/{zineId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || request.auth.uid in resource.data.collaborators);
    }
    
    // PUBLIC TRANSMISSIONS (Proscenium)
    match /public_transmissions/{transmissionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if true; // Allow anyone to increment likes and add vibe notes
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // POCKET ITEMS (Owner or Collaborator)
    match /pocket/{itemId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || ('collaborators' in resource.data && request.auth.uid in resource.data.collaborators));
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || ('collaborators' in resource.data && request.auth.uid in resource.data.collaborators));
    }
    
    // DOSSIER FOLDERS (Owner or Collaborator)
    match /dossier_folders/{folderId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || ('collaborators' in resource.data && request.auth.uid in resource.data.collaborators));
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || ('collaborators' in resource.data && request.auth.uid in resource.data.collaborators));
    }
    
    // DOSSIER ARTIFACTS (Owner, Collaborator, or Folder Access)
    match /dossier_artifacts/{artifactId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        ('collaborators' in resource.data && request.auth.uid in resource.data.collaborators) ||
        (
          exists(/databases/$(database)/documents/dossier_folders/$(resource.data.folderId)) &&
          (
            get(/databases/$(database)/documents/dossier_folders/$(resource.data.folderId)).data.userId == request.auth.uid ||
            ('collaborators' in get(/databases/$(database)/documents/dossier_folders/$(resource.data.folderId)).data && request.auth.uid in get(/databases/$(database)/documents/dossier_folders/$(resource.data.folderId)).data.collaborators)
          )
        )
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid && (
        exists(/databases/$(database)/documents/dossier_folders/$(request.resource.data.folderId)) &&
        (
          get(/databases/$(database)/documents/dossier_folders/$(request.resource.data.folderId)).data.userId == request.auth.uid ||
          ('collaborators' in get(/databases/$(database)/documents/dossier_folders/$(request.resource.data.folderId)).data && request.auth.uid in get(/databases/$(database)/documents/dossier_folders/$(request.resource.data.folderId)).data.collaborators)
        )
      );
      allow update, delete: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        ('collaborators' in resource.data && request.auth.uid in resource.data.collaborators) ||
        (
          exists(/databases/$(database)/documents/dossier_folders/$(resource.data.folderId)) &&
          (
            get(/databases/$(database)/documents/dossier_folders/$(resource.data.folderId)).data.userId == request.auth.uid ||
            ('collaborators' in get(/databases/$(database)/documents/dossier_folders/$(resource.data.folderId)).data && request.auth.uid in get(/databases/$(database)/documents/dossier_folders/$(resource.data.folderId)).data.collaborators)
          )
        )
      );
    }
    
    // PROPOSALS (Owner or Collaborator)
    match /proposals/{proposalId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || ('collaborators' in resource.data && request.auth.uid in resource.data.collaborators));
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || ('collaborators' in resource.data && request.auth.uid in resource.data.collaborators));
    }
    
    // CONTEXT (Owner only)
    match /context/{contextId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // CONNECTIONS (Friends/Following)
    match /connections/{connectionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.followerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.followerId == request.auth.uid;
    }

    // FRIEND REQUESTS
    match /friend_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }
    
    // FRIENDSHIPS
    match /friendships/{friendshipId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.resource.data.user1 == request.auth.uid || request.resource.data.user2 == request.auth.uid);
      allow update, delete: if request.auth != null && (resource.data.user1 == request.auth.uid || resource.data.user2 == request.auth.uid);
    }

    // ZINE COMMENTS
    match /zine_comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // STATS (Publicly readable)
    match /stats/{docId} {
      allow read: if true;
    }
  }
}
