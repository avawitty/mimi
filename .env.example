# MIMI ZINE - ENVIRONMENT CONFIGURATION
# Set these variables in your deployment dashboard (Vercel, Netlify, Cloud Run, etc.)

# 1. GOOGLE GEMINI API KEY (Required for AI features)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# 2. FIREBASE CONFIGURATION (Required for database/storage)
# Get these from your Firebase Console -> Project Settings
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# 3. WEB PUSH NOTIFICATIONS
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
